	st4.Text = "• Result: Processing"
	barFill.Size = UDim2.new(0,0,1,0)
	percent.Text = "0%"
	circleText.Text = "0%"
	addLog("[START] process initialized", Color3.fromRGB(255,255,170))

	for i = 1, 100 do
		local msg = fakeTexts[math.random(1, #fakeTexts)] .. "..."
		status.Text = msg
		percent.Text = i .. "%"
		circleText.Text = i .. "%"
		ring.Rotation = ring.Rotation + 14

		TweenService:Create(barFill, TweenInfo.new(0.8, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
			Size = UDim2.new(i/100, 0, 1, 0)
		}):Play()

		if i % 3 == 0 then
			addLog(string.format("[STEP %03d] %s", i, msg), Color3.fromRGB(180,220,255))
		end
		if i % 5 == 0 then
			tickSound:Play()
		end
		if i == 25 then
			st2.Text = "• Tunnel: High Load"
			addLog("[WARN] server load increased", Color3.fromRGB(255,220,120))
		elseif i == 55 then
			st3.Text = "• Validation: Running"
			addLog("[CHECK] validation layer enabled", Color3.fromRGB(120,255,170))
		elseif i == 82 then
			st4.Text = "• Result: Unstable"
			addLog("[WARN] unstable response detected", Color3.fromRGB(255,150,150))
		end

		task.wait(1)
	end

	errorSound:Play()
	status.Text = "Ошибка, попробуйте еще раз"
	desc.Text = "Во время обработки произошла неизвестная ошибка."
	dupe.Text = "TRY AGAIN"
	dupe.Active = true
	loading = false
	st4.Text = "• Result: Failed"

	addLog("[ERROR] unknown exception returned", Color3.fromRGB(255,140,140))
	addLog("[STOP] process aborted", Color3.fromRGB(255,180,180))

	TweenService:Create(dupe, TweenInfo.new(0.18), {
		BackgroundColor3 = Color3.fromRGB(255,70,90)
	}):Play()
	task.wait(0.22)
	TweenService:Create(dupe, TweenInfo.new(0.22), {
		BackgroundColor3 = Color3.fromRGB(0,145,255)
	}):Play()
end)


local pulse = 0
RunService.RenderStepped:Connect(function(dt)
	pulse += dt

	local a = (math.sin(pulse * 2) + 1) / 2
	local b = (math.sin(pulse * 1.2) + 1) / 2
	local c = (math.sin(pulse * 2.5) + 1) / 2

	neonStroke.Transparency = 0.18 + a * 0.42
	mainStroke.Transparency = 0.05 + b * 0.18
	glow.ImageTransparency = 0.18 + a * 0.2
	logo.Rotation = math.sin(pulse * 1.4) * 3
	ring.Rotation = ring.Rotation + dt * 45

	footer.TextColor3 = Color3.fromRGB(
		0,
		170 + math.floor(50 * b),
		220 + math.floor(35 * c)
	)

	local basePos = main.Position
	for _, p in ipairs(particles) do
		local x = math.cos(pulse * p.speed + p.angle) * p.radius
		local y = math.sin(pulse * p.speed + p.angle) * (p.radius * 0.55)
		p.obj.Position = UDim2.new(basePos.X.Scale, basePos.X.Offset + x, basePos.Y.Scale, basePos.Y.Offset + y)
		p.obj.BackgroundTransparency = 0.55 + 0.25 * math.sin(pulse * p.speed + p.angle)
	end
end)

local function startFakeLoad(scriptName)
	if loading then
		return
	end

	loading = true
	menuPage.Visible = false
	loadingPage.Visible = true

	loadTitle.Text = scriptName
	loadSub.Text = "Loading simulation"
	status.Text = "Starting..."
	resultLabel.Text = ""
	barFill.Size = UDim2.new(0, 0, 1, 0)
	percent.Text = "0%"

	for i = 1, 100 do
		status.Text = fakeTexts[math.random(1, #fakeTexts)]
		percent.Text = i .. "%"
		TweenService:Create(barFill, TweenInfo.new(0.8, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
			Size = UDim2.new(i / 100, 0, 1, 0)
		}):Play()
		task.wait(1)
	end

	status.Text = "Failed"
	resultLabel.Text = "Ошибка, попробуйте еще раз"
	loading = false
end

startBtn.MouseButton1Click:Connect(function()

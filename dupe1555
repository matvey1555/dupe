local currentTab = "Main"
local function switchTab(name)
	currentTab = name
	for tabName, tabData in pairs(tabButtons) do
		if tabName == name then
			tabData.button.BackgroundColor3 = Color3.fromRGB(0,120,220)
			tabData.stroke.Color = Color3.fromRGB(120,230,255)
			tabData.stroke.Transparency = 0.05
		else
			tabData.button.BackgroundColor3 = Color3.fromRGB(22,28,42)
			tabData.stroke.Color = Color3.fromRGB(70,110,170)
			tabData.stroke.Transparency = 0.25
		end
	end
	for pageName, pageObj in pairs(pages) do
		pageObj.Visible = (pageName == name)
	end
end


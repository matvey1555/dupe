local selectedScript = nil
local buttons = {
	["Freeze"] = freezeBtn,
	["Duel"] = duelBtn,
	["Dupe"] = dupeBtn,
	["Instant Steal"] = stealBtn
}

local function refreshSelection()
	for name, btn in pairs(buttons) do
		if name == selectedScript then
			btn.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
			btn.TextColor3 = Color3.fromRGB(30,30,40)
		else
			btn.BackgroundColor3 = Color3.fromRGB(0, 145, 255)
			btn.TextColor3 = Color3.fromRGB(0,0,0)
		end
	end
	selectedLabel.Text = "Selected: " .. (selectedScript or "none")
end

for name, btn in pairs(buttons) do
	btn.MouseButton1Click:Connect(function()
		selectedScript = name
		refreshSelection()
	end)
end

refreshSelection()

